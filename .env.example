# web-counter 环境变量配置
# 复制此文件为 .env 并修改

# [必填] IP 哈希盐值，用于保护访客隐私
# 生成方式：openssl rand -hex 16
COUNTER_SALT=

# 监听地址
COUNTER_HOST=0.0.0.0

# 监听端口
COUNTER_PORT=8000

# SQLite 数据库文件路径
COUNTER_DB_PATH=./data/counter.db

# PID 文件路径（用于进程管理）
COUNTER_PID_FILE=./data/counter.pid

# CORS 允许的域名，逗号分隔，* 表示所有域名
COUNTER_ALLOWED_ORIGINS=*

# 每 IP 每分钟限流次数
COUNTER_RATE_LIMIT=60
